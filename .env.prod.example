APP_NAME=cheersstudio
APP_DIR=/www/wwwroot/cheersstudio
SPRING_PROFILES_ACTIVE=prod

# Bind only to localhost to avoid conflicting with existing public listeners.
FRONTEND_PORT_MAPPING=127.0.0.1:8089:3000
BACKEND_SERVER_PORT=8081

# Leave empty for same-origin /api requests behind Nginx.
NEXT_PUBLIC_API_BASE_URL=

APP_CORS_ALLOWED_ORIGINS=https://studio.wandcheers.xyz
APP_JWT_SECRET=replace-with-a-long-random-secret

SPRING_DATASOURCE_URL=jdbc:mysql://127.0.0.1:3306/cheersstudio?useUnicode=true&characterEncoding=utf8&serverTimezone=Asia/Shanghai&allowPublicKeyRetrieval=true&useSSL=false
SPRING_DATASOURCE_USERNAME=cheersstudio
SPRING_DATASOURCE_PASSWORD=replace-with-a-strong-db-password

ALIYUN_OSS_ENABLED=false
ALIYUN_OSS_ENDPOINT=oss-cn-beijing.aliyuncs.com
ALIYUN_OSS_REGION=cn-beijing
ALIYUN_OSS_BUCKET_NAME=
ALIYUN_OSS_ACCESS_KEY_ID=
ALIYUN_OSS_ACCESS_KEY_SECRET=
ALIYUN_OSS_OBJECT_PREFIX=cheers-studio
ALIYUN_OSS_PUBLIC_URL_PREFIX=

JAVA_OPTS=-Xms256m -Xmx512m
